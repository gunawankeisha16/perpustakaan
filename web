USE db_buku;

CREATE TABLE buku (
    id INT AUTO_INCREMENT PRIMARY KEY,
    kode_buku VARCHAR(20),
    judul_buku VARCHAR(100),
    nama_pengarang VARCHAR(100),
    tahun_terbit INT
);

